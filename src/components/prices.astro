---
interface Props {
  title: string;
  description: string;
  price: string;
  features: string[];
}
const { title, description, price, features } = Astro.props;
---

<div
  class="flex w-full max-w-130 flex-col items-center justify-center gap-10 rounded-3xl border border-slate-800 bg-white bg-linear-to-b from-white to-blue-600 p-8 text-center md:w-180 md:p-12"
>
  <h3 class="mt-4 text-3xl leading-tight font-bold md:text-7xl">{title}</h3>
  <h4 class="mt-4 text-xl font-bold md:text-4xl">{description}</h4>

  <ul class="mt-10 font-mono text-xl font-bold">
    {
      features.map((item) => (
        <li class="gap-2">
          <span class="text-emerald-400">✓</span> {item}
        </li>
      ))
    }
  </ul>

  <span class="mt-20 font-mono text-3xl font-bold text-white">{price}</span>
</div>
